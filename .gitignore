# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment/uncomment to suit your preference.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you do not want it, uncomment:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be in version control.
#   However, if you wish to ignore it, uncomment:
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be in version control.
#   pdm.lock
#   pdm.toml
.pdm-plugins/

# pyflow
.pyflow/

# venv
#   Useful to ignore local virtual environments
.venv/
venv/
